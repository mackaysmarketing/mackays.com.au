# Mackays Marketing website — environment variables
#
# Copy this file to `.env.local` (never commit `.env.local`) and
# fill in the real values from your Mapbox / Resend / Vercel dashboards.
#
# On Vercel: add each key under Project Settings → Environment Variables
# for both Production and Preview.

# Mapbox token used by react-map-gl on the Produce overview, Our
# Produce bento callouts (if enabled in a later phase), the homepage
# regions map and the Contact page static map. The fallback panel in
# QldFarmMap triggers if this is unset.
# Dashboard: https://mapbox.com → Account → Tokens
# Starts with: pk.eyJ1...
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...

# Resend API key used by the /api/contact POST handler. A missing key
# returns 503 `service_not_configured` at request time so the build
# never silently succeeds on a misconfigured environment.
# Dashboard: https://resend.com → API Keys
# Starts with: re_
RESEND_API_KEY=re_...

# Canonical site URL used by metadataBase, sitemap, robots, JSON-LD
# schemas, and the `from` address on outbound contact emails. Used to
# derive the `website@{hostname}` address in /api/contact. Must be a
# fully qualified URL with protocol.
NEXT_PUBLIC_SITE_URL=https://mackays.com.au
